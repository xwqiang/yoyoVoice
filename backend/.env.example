# App
SECRET_KEY=change-me-to-a-random-secret-key
DATABASE_URL=sqlite:///../data/yoyovoice.db
CORS_ORIGINS=*

# Azure Speech (pronunciation assessment + optional TTS)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# AI - OpenAI-compatible API (word import, recommendations, reports)
# Option 1: Use OpenAI directly
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Option 2: Use Cursor API key (falls back to https://api.cursor.com/v1)
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5
